{
  "redirects": [
    {
      "source": "/((?!dashboard|api).*)",
      "has": [
        {
          "type": "host",
          "value": "aamathakalirestro.com.np"
        }
      ],
      "destination": "https://www.aamathakalirestro.com.np/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/dashboard",
      "destination": "https://aama-thakali-restro-and-bar-ehne.vercel.app/dashboard"
    },
    {
      "source": "/dashboard/:path*",
      "destination": "https://aama-thakali-restro-and-bar-ehne.vercel.app/dashboard/:path*"
    }
  ]
}